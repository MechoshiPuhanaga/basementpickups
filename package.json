{
  "name": "basement_pickups_web_site",
  "description": "Basement pickups web site",
  "version": "2.0.0",
  "repository": "git@github.com:MechoshiPuhanaga/basementpickups.git",
  "homepage": "git@github.com:MechoshiPuhanaga/basementpickups.git",
  "author": "Mechoshi Puhanaga",
  "contributors": [
    {
      "email": "mechokio@gmail.com",
      "name": "Mechoshi Puhanaga",
      "url": "https://github.com/MechoshiPuhanaga"
    }
  ],
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.2.2"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "NODE_ENV=production tsx server/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"src/**/*.css\"",
    "typecheck": "tsc --noEmit",
    "optimize:images": "node scripts/optimize-images.mjs",
    "audit:lighthouse": "node scripts/audit-lighthouse.mjs"
  },
  "dependencies": {
    "express": "5.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.0.1",
    "resend": "6.14.0",
    "tsx": "4.22.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "sharp": "0.35.2",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16"
  }
}
